rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Get admin data for the given email
    function getAdmin(email) {
      return get(/databases/$(database)/documents/admins/$(email)).data;
    }

    // Check if user has one of the required roles
    function hasRole(email, roles) {
      let admin = getAdmin(email);
      return admin != null && admin.role in roles;
    }

    // Role-specific helpers
    function isOwner(email) { return hasRole(email, ['owner']); }
    function isAdmin(email) { return hasRole(email, ['owner', 'admin']); }
    function isEditor(email) { return hasRole(email, ['owner', 'admin', 'editor']); }

    // Validates an Event document
    function isValidEvent() {
      let data = request.resource.data;
      return
        data.keys().hasAll(['artistName', 'eventName', 'eventDate', 'venueName', 'isPublished']) &&
        data.artistName is string &&
        data.eventName is string &&
        data.eventDate is timestamp &&
        data.venueName is string &&
        data.isPublished is bool &&
        (!data.keys().hasAny(['isClosed']) || data.isClosed is bool) &&
        (!data.keys().hasAny(['dates']) || data.dates is list) &&
        (!data.keys().hasAny(['schedule']) || data.schedule is list) &&
        (!data.keys().hasAny(['imageUrl']) || data.imageUrl is string || data.imageUrl == null) &&
        (!data.keys().hasAny(['imagePath']) || data.imagePath is string || data.imagePath == null);
    }

    // Validates a Newsletter subscription document
    function isValidNewsletterSubscription() {
      let data = request.resource.data;
      return
        data.keys().hasAll(['name', 'email', 'subscribedAt', 'status']) &&
        data.name is string &&
        data.email is string &&
        data.email.size() > 5 &&
        data.email.size() < 255 &&
        data.status is string &&
        data.status in ['active', 'unsubscribed'];
    }

    // Validates a Transportation Quote request
    function isValidTransportationQuote() {
      let data = request.resource.data;
      return
        data.keys().hasAll(['fullName', 'phone', 'email', 'eventDate', 'passengers', 'vehiclePreference', 'pickupLocation', 'status', 'submittedAt']) &&
        data.fullName is string &&
        data.phone is string &&
        data.email is string &&
        data.eventDate is string &&
        data.passengers is number && data.passengers > 0 &&
        data.vehiclePreference is string &&
        data.pickupLocation is string &&
        data.status is string &&
        data.submittedAt is timestamp &&
        (!data.keys().hasAny(['eventShow']) || data.eventShow is string) &&
        (!data.keys().hasAny(['additionalNotes']) || data.additionalNotes is string);
    }

    // Validates a VIP Request
    function isValidVipRequest() {
      let data = request.resource.data;
      return
        data.keys().hasAll(['fullName', 'phone', 'email', 'eventDetails', 'groupSize', 'requestedServices', 'status', 'submittedAt']) &&
        data.fullName is string &&
        data.phone is string &&
        data.email is string &&
        data.eventDetails is string &&
        data.groupSize is number && data.groupSize > 0 &&
        data.requestedServices is string &&
        data.status is string &&
        data.submittedAt is timestamp &&
        (!data.keys().hasAny(['specialRequests']) || data.specialRequests is string);
    }

    // Validates a Contact Request
    function isValidContactRequest() {
      let data = request.resource.data;
      return
        data.keys().hasAll(['name', 'email', 'phone', 'subject', 'message', 'status', 'createdAt']) &&
        data.name is string &&
        data.email is string &&
        data.phone is string &&
        data.subject is string &&
        data.message is string &&
        data.status is string &&
        data.createdAt is timestamp;
    }

    // --- Collection Rules ---

    // Events collection
    match /events/{event} {
      allow read: if true;
      // Owners, Admins, and Editors can create/update
      allow create, update: if request.auth != null && isEditor(request.auth.token.email) && isValidEvent();
      // Only Owners and Admins can delete events
      allow delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Admins collection
    match /admins/{adminDoc} {
      // Any authenticated user can read (needed for role check)
      allow read: if request.auth != null;
      // ONLY Owners can create/delete/update other admins
      allow create, delete, update: if request.auth != null && isOwner(request.auth.token.email);
    }

    // Newsletter subscribers collection
    match /newsletter/{subscriber} {
      // Only Owners and Admins can read subscriber data (prevents email scraping)
      allow read: if request.auth != null && isAdmin(request.auth.token.email);
      allow create: if isValidNewsletterSubscription();
      // Only Owners and Admins can manage subscribers
      allow update, delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Transportation Quotes collection
    match /transportation_quotes/{quote} {
      // Anyone can submit a quote request
      allow create: if isValidTransportationQuote();
      // Only Admins can view and manage quotes
      allow read, update, delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // VIP Requests collection
    match /vip_requests/{request} {
      // Anyone can submit a VIP request
      allow create: if isValidVipRequest();
      // Only Admins can view and manage requests
      allow read, update, delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Contact Requests collection
    match /contact_requests/{request} {
      // Anyone can submit a contact request
      allow create: if isValidContactRequest();
      // Only Admins can view and manage requests
      allow read, update, delete: if request.auth != null && isAdmin(request.auth.token.email);
    }

    // Scrape logs collection
    match /scrape_logs/{log} {
      // Only Admins can read scrape logs
      allow read: if request.auth != null && isAdmin(request.auth.token.email);
      // No client-side writes (logs created by backend scripts)
      allow write: if false;
    }

    // Deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
